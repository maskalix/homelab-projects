PUID=1000
PGID=1000

# =========================================================================
# Pocket ID
# Docs: https://pocket-id.org/docs/configuration/environment-variables
# =========================================================================

# Host port mapping (host:1411)
POCKET_ID_PORT=4000

# Public URL of your Pocket ID instance (must be HTTPS for WebAuthn/passkeys)
APP_URL=https://POCKET_ID_URL

# Set to true when running behind a reverse proxy (Traefik, NPM, Caddy, ...)
TRUST_PROXY=true

# Encryption key for sensitive data
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# =========================================================================
# TinyAuth
# Docs: https://tinyauth.app/docs/reference/configuration/
# =========================================================================

# Host port mapping (host:3000)
TINYAUTH_PORT=4001

# Public URL of your TinyAuth instance (used for cookies + redirects)
TINYAUTH_APPURL=https://TINYAUTH_URL

# Customize
# Path to the background image. Default: /background.jpg
TINYAUTH_UI_BACKGROUNDIMAGE=https://
TINYAUTH_UI_TITLE="TinyAuth Proxy"


# Secret used to sign sessions - must be exactly 32 characters
# Generate with: openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32
TINYAUTH_SECRET=

# Users in the format username:bcrypt-hash (comma separated for multiple users)
# Generate with:
#   docker run --rm -it ghcr.io/steveiliop56/tinyauth:v5 user create --interactive
# Pick "Format for Docker" so $ characters are escaped 
#TINYAUTH_AUTH_USERS='username:$2a$10$bunchofrandomcharacters'
#
TINYAUTH_OAUTH_PROVIDERS_POCKETID_NAME='Pocket ID'
TINYAUTH_OAUTH_PROVIDERS_POCKETID_CLIENTID=''
TINYAUTH_OAUTH_PROVIDERS_POCKETID_CLIENTSECRET=''
TINYAUTH_OAUTH_PROVIDERS_POCKETID_AUTHURL=https://POCKET_ID_URL/authorize
TINYAUTH_OAUTH_PROVIDERS_POCKETID_TOKENURL=https://POCKET_ID_URL/api/oidc/token
TINYAUTH_OAUTH_PROVIDERS_POCKETID_USERINFOURL=https://POCKET_ID_URL/api/oidc/userinfo
TINYAUTH_OAUTH_PROVIDERS_POCKETID_REDIRECTURL=https://TINYAUTH_URL/api/oauth/callback/pocketid
TINYAUTH_OAUTH_PROVIDERS_POCKETID_SCOPES=openid email profile groups
#
TINYAUTH_OAUTH_AUTOREDIRECT=pocketid
